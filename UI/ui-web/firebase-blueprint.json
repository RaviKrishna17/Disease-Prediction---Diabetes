{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information containing patient details.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The patient full name" },
        "email": { "type": "string", "format": "email", "description": "The patient email address" },
        "phone": { "type": "string", "description": "The contact number" },
        "bloodGroup": { "type": "string", "description": "The blood group and classification" },
        "dob": { "type": "string", "description": "The patient birth date" },
        "heightWeight": { "type": "string", "description": "The height and weight values" },
        "patientId": { "type": "string", "description": "MRN unique patient identifier" }
      },
      "required": ["name", "email", "phone"]
    },
    "PredictionRecord": {
      "title": "PredictionRecord",
      "description": "Individually logged early screening assessment records with calculated diabetic risk coefficients.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "DS screening identifier" },
        "date": { "type": "string", "description": "Formatted snapshot timestamp of assessment" },
        "riskPercentage": { "type": "integer", "description": "The calculated risk level out of 100" },
        "riskLevel": { "type": "string", "enum": ["Low", "Moderate", "High"], "description": "Aggregated risk severity bucket" },
        "age": { "type": "integer", "description": "Recorded age at screening time" },
        "gender": { "type": "string", "description": "Patient sex indicator" },
        "bmi": { "type": "number", "description": "Calculated BMI value" },
        "glucose": { "type": "integer", "description": "Fasting blood plasma glucose level" },
        "hba1c": { "type": "number", "description": "HbA1c protein metrics" },
        "systolicBP": { "type": "integer", "description": "Systolic blood pressure reading" },
        "diastolicBP": { "type": "integer", "description": "Diastolic blood pressure reading" },
        "recommendations": { "type": "array", "description": "Aggregated medical and diet optimization action points" },
        "clinicalNotes": { "type": "string", "description": "Aggregated medical overview text" }
      },
      "required": ["id", "date", "riskPercentage", "riskLevel"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "Holds isolated custom user profiles with strict owner-based restrictions."
    },
    "users/{userId}/predictions/{predictionId}": {
      "schema": "PredictionRecord",
      "description": "Holds the timeline history list of screening outputs generated by users."
    }
  }
}
